generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  phone              String?
  registrationNumber String? // state medical council registration no.
  clinicName         String?
  passwordHash       String? // scrypt hash; null until a password is set
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tokens               ApiToken[]
  patients             Patient[]
  dischargeSummaries   DischargeSummary[]
  auditLogs            AuditLog[]
  encounters           Encounter[]
  prescriptions        Prescription[]
  idempotencyKeys      IdempotencyKey[]
  telegramLink         TelegramLink?
  pendingActions       PendingAction[]
  conversationMessages ConversationMessage[]
  loginTokens          LoginToken[]
  webSessions          WebSession[]
  attachments          Attachment[]
  passwordResetTokens  PasswordResetToken[]
}

model ApiToken {
  id         String    @id @default(cuid())
  doctorId   String
  name       String // e.g. "telegram-agent", "dev"
  tokenHash  String    @unique // sha256 of the raw token; raw token is never stored
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  doctor    Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([doctorId])
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

model Patient {
  id                String    @id @default(cuid())
  doctorId          String
  name              String
  dateOfBirth       DateTime? @db.Date
  dobApproximate    Boolean   @default(false) // true when derived from an age, not a known DOB
  sex               Sex       @default(UNKNOWN)
  phone             String?
  abhaId            String? // ABDM health account id, optional
  bloodGroup        String?
  allergies         String[]  @default([])
  chronicConditions String[]  @default([])
  currentMedications Json? // [{ name, dose, frequency, duration? }]
  notes             String?
  archivedAt        DateTime? // soft-delete: hidden from lists, kept for audit
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  doctor             Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dischargeSummaries DischargeSummary[]
  encounters         Encounter[]
  prescriptions      Prescription[]
  attachments        Attachment[]

  @@index([doctorId, name])
  @@index([doctorId, phone])
}

enum AttachmentKind {
  PRESCRIPTION
  DISCHARGE_SUMMARY
  LAB_REPORT
  OTHER
}

// A doctor-uploaded image/document (e.g. a photo of a paper prescription),
// stored privately in R2. Access is always via short-lived presigned URLs.
// uploadedAt is null until the client confirms the R2 PUT succeeded.
model Attachment {
  id                 String         @id @default(cuid())
  doctorId           String
  patientId          String
  kind               AttachmentKind @default(OTHER)
  prescriptionId     String? // optional link to a specific record
  dischargeSummaryId String?
  r2Key              String         @unique
  contentType        String
  fileName           String?
  source             String         @default("web") // "web" | "telegram"
  uploadedAt         DateTime?
  createdAt          DateTime       @default(now())

  doctor           Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription     Prescription?     @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  dischargeSummary DischargeSummary? @relation(fields: [dischargeSummaryId], references: [id], onDelete: SetNull)

  @@index([patientId, kind])
  @@index([doctorId])
}

model Encounter {
  id          String   @id @default(cuid())
  doctorId    String
  patientId   String
  date        DateTime @db.Date
  complaint   String
  examination String?
  vitals      Json? // { "bp": "130/85", "pulse": 78, "temp": "98.6 F", "spo2": 98, ... }
  diagnosis   String?
  plan        String?
  notes       String?
  archivedAt  DateTime? // soft-delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([patientId, date])
  @@index([doctorId])
}

model Prescription {
  id                  String    @id @default(cuid())
  doctorId            String
  patientId           String
  encounterId         String?
  date                DateTime  @db.Date
  medications         Json // [{ name, dose, frequency, duration? }]
  advice              String?
  followUpDate        DateTime? @db.Date
  documentKey         String? // R2 object key of the generated PDF
  documentGeneratedAt DateTime?
  archivedAt          DateTime? // soft-delete
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter   Encounter?   @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([patientId, date])
  @@index([doctorId])
}

enum SummaryStatus {
  DRAFT
  FINAL
}

model DischargeSummary {
  id                      String        @id @default(cuid())
  doctorId                String
  patientId               String
  status                  SummaryStatus @default(DRAFT)
  admissionDate           DateTime      @db.Date
  dischargeDate           DateTime      @db.Date
  diagnosis               String
  presentingComplaint     String?
  hospitalCourse          String
  investigations          String?
  treatmentGiven          String?
  conditionAtDischarge    String?
  medicationsAtDischarge  Json? // [{ name, dose, frequency, duration? }]
  followUpInstructions    String?
  documentKey             String? // R2 object key of the generated PDF
  documentGeneratedAt     DateTime?
  archivedAt              DateTime? // soft-delete
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([doctorId])
  @@index([patientId])
}

// Replay protection for write endpoints: same (doctor, key) returns the stored
// response instead of re-executing. Rows with a null responseStatus are in flight.
model IdempotencyKey {
  id             String   @id @default(cuid())
  doctorId       String
  key            String
  responseStatus Int?
  responseBody   Json?
  createdAt      DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, key])
}

// Bridge between a Telegram chat and a doctor. Created with a one-time link
// code; the doctor sends "/link <code>" to the bot to claim it.
model TelegramLink {
  id                 String    @id @default(cuid())
  doctorId           String    @unique
  chatId             String?   @unique
  linkCode           String    @unique
  linkCodeExpiresAt  DateTime?
  linkedAt           DateTime?
  createdAt          DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

// Webhook replay protection: Telegram redelivers updates it thinks we missed;
// an update_id that is already here has been handled and must be skipped.
model ProcessedTelegramUpdate {
  updateId  BigInt   @id
  createdAt DateTime @default(now())
}

enum PendingActionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

// Confirm-before-write: the agent proposes a change here; it is executed only
// after the doctor confirms in a LATER message. Enforced server-side.
model PendingAction {
  id         String              @id @default(cuid())
  doctorId   String
  type       String // "patient.create" | "patient.update" | "encounter.create" | ...
  payload    Json
  status     PendingActionStatus @default(PENDING)
  expiresAt  DateTime
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, status])
}

// One-time magic-link token minted by the bot's /web command. Exchanged once,
// within a short window, for a WebSession. Only the sha256 hash is stored.
model LoginToken {
  id        String    @id @default(cuid())
  doctorId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}

// Browser session established after a magic link is exchanged. The cookie holds
// the raw id; only its sha256 hash is stored. Revocable and auto-expiring.
model WebSession {
  id          String    @id @default(cuid())
  doctorId    String
  sessionHash String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}

// One-time password-reset token, delivered to the doctor's linked Telegram.
// Only the sha256 hash is stored; consumed once, within a short window.
model PasswordResetToken {
  id        String    @id @default(cuid())
  doctorId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}

// Chat history for agent context across serverless invocations.
model ConversationMessage {
  id        String   @id @default(cuid())
  doctorId  String
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  doctorId     String
  tokenId      String?
  action       String // e.g. "patient.create", "patient.read", "summary.document.download"
  resourceType String // "Patient" | "DischargeSummary" | ...
  resourceId   String?
  details      Json?
  createdAt    DateTime @default(now())

  doctor Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  token  ApiToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([resourceType, resourceId])
}

// Fixed-window rate limiting, DB-backed so it works across serverless instances.
// One row per (key, window-start); count increments within the window.
model RateLimitHit {
  id          String   @id @default(cuid())
  bucket      String // e.g. "login:1.2.3.4" or "connect-code:<doctorId>"
  windowStart DateTime
  count       Int      @default(1)

  @@unique([bucket, windowStart])
  @@index([windowStart])
}
