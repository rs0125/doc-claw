generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  phone              String?
  registrationNumber String? // state medical council registration no.
  clinicName         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tokens               ApiToken[]
  patients             Patient[]
  dischargeSummaries   DischargeSummary[]
  auditLogs            AuditLog[]
  encounters           Encounter[]
  prescriptions        Prescription[]
  idempotencyKeys      IdempotencyKey[]
  telegramLink         TelegramLink?
  pendingActions       PendingAction[]
  conversationMessages ConversationMessage[]
}

model ApiToken {
  id         String    @id @default(cuid())
  doctorId   String
  name       String // e.g. "telegram-agent", "dev"
  tokenHash  String    @unique // sha256 of the raw token; raw token is never stored
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  doctor    Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([doctorId])
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

model Patient {
  id                String    @id @default(cuid())
  doctorId          String
  name              String
  dateOfBirth       DateTime? @db.Date
  sex               Sex       @default(UNKNOWN)
  phone             String?
  abhaId            String? // ABDM health account id, optional
  bloodGroup        String?
  allergies         String[]  @default([])
  chronicConditions String[]  @default([])
  currentMedications Json? // [{ name, dose, frequency, duration? }]
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  doctor             Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dischargeSummaries DischargeSummary[]
  encounters         Encounter[]
  prescriptions      Prescription[]

  @@index([doctorId, name])
  @@index([doctorId, phone])
}

model Encounter {
  id          String   @id @default(cuid())
  doctorId    String
  patientId   String
  date        DateTime @db.Date
  complaint   String
  examination String?
  vitals      Json? // { "bp": "130/85", "pulse": 78, "temp": "98.6 F", "spo2": 98, ... }
  diagnosis   String?
  plan        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([patientId, date])
  @@index([doctorId])
}

model Prescription {
  id                  String    @id @default(cuid())
  doctorId            String
  patientId           String
  encounterId         String?
  date                DateTime  @db.Date
  medications         Json // [{ name, dose, frequency, duration? }]
  advice              String?
  followUpDate        DateTime? @db.Date
  documentKey         String? // R2 object key of the generated PDF
  documentGeneratedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  doctor    Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([patientId, date])
  @@index([doctorId])
}

enum SummaryStatus {
  DRAFT
  FINAL
}

model DischargeSummary {
  id                      String        @id @default(cuid())
  doctorId                String
  patientId               String
  status                  SummaryStatus @default(DRAFT)
  admissionDate           DateTime      @db.Date
  dischargeDate           DateTime      @db.Date
  diagnosis               String
  presentingComplaint     String?
  hospitalCourse          String
  investigations          String?
  treatmentGiven          String?
  conditionAtDischarge    String?
  medicationsAtDischarge  Json? // [{ name, dose, frequency, duration? }]
  followUpInstructions    String?
  documentKey             String? // R2 object key of the generated PDF
  documentGeneratedAt     DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
}

// Replay protection for write endpoints: same (doctor, key) returns the stored
// response instead of re-executing. Rows with a null responseStatus are in flight.
model IdempotencyKey {
  id             String   @id @default(cuid())
  doctorId       String
  key            String
  responseStatus Int?
  responseBody   Json?
  createdAt      DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, key])
}

// Bridge between a Telegram chat and a doctor. Created with a one-time link
// code; the doctor sends "/link <code>" to the bot to claim it.
model TelegramLink {
  id        String    @id @default(cuid())
  doctorId  String    @unique
  chatId    String?   @unique
  linkCode  String    @unique
  linkedAt  DateTime?
  createdAt DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

enum PendingActionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

// Confirm-before-write: the agent proposes a change here; it is executed only
// after the doctor confirms in a LATER message. Enforced server-side.
model PendingAction {
  id         String              @id @default(cuid())
  doctorId   String
  type       String // "patient.create" | "patient.update" | "encounter.create" | ...
  payload    Json
  status     PendingActionStatus @default(PENDING)
  expiresAt  DateTime
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, status])
}

// Chat history for agent context across serverless invocations.
model ConversationMessage {
  id        String   @id @default(cuid())
  doctorId  String
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  doctorId     String
  tokenId      String?
  action       String // e.g. "patient.create", "patient.read", "summary.document.download"
  resourceType String // "Patient" | "DischargeSummary" | ...
  resourceId   String?
  details      Json?
  createdAt    DateTime @default(now())

  doctor Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  token  ApiToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([doctorId, createdAt])
  @@index([resourceType, resourceId])
}
